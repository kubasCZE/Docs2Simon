{
  "compilerOptions": {
    "jsx": "react",
    "lib": ["es6", "dom"],
    "rootDir": "src",
    "module": "commonjs",
    "target": "es5",
    "sourceMap": true,
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "./types",
      "node_modules/@types",
      "node_modules/uxp-types",
      "node_modules/@adobe/cc-ext-uxp-types"
    ]
  },
  "include": ["./src"],
  "exclude": ["node_modules", "build"]
}
